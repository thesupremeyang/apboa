# ============================================================
# Apboa Docker 部署环境配置
# ============================================================
# 说明：
#   - 内置服务：docker-compose 自动启动 MySQL/Redis/pgvector 容器
#   - 外置服务：将 HOST 改为外部地址，并在 docker-compose.yml 中
#     注释掉对应服务块（及 backend 的 depends_on 中对应项）
# ============================================================

# ==================== MySQL 配置 ====================
MYSQL_HOST=apboa-mysql
MYSQL_PORT=3306
MYSQL_DATABASE=apboa
MYSQL_USER=root
MYSQL_PASSWORD=root
MYSQL_ROOT_PASSWORD=root

# ==================== Redis 配置 ====================
REDIS_HOST=apboa-redis
REDIS_PORT=6379
REDIS_PASSWORD=redis
REDIS_DATABASE=7

# ==================== 向量库配置 ====================
# 支持: pgvector | milvus | qdrant | elasticsearch，留空则禁用向量库
VECTOR_STORE_TYPE=pgvector
# Docker Compose 内置向量库开关。设为 external 或留空时只连接外部向量库，不拉取或启动内置向量库容器。
# 本地快速启动默认启用内置 pgvector；使用外部 pgvector/elasticsearch/milvus/qdrant 时请设为 external。
COMPOSE_PROFILES=pgvector

# pgvector 配置（VECTOR_STORE_TYPE=pgvector 时生效）
PG_HOST=apboa-pgvector
PG_PORT=5432
PG_DATABASE=apboa_vector
PG_USER=postgres
PG_PASSWORD=postgres

# Milvus 配置（VECTOR_STORE_TYPE=milvus 时生效）
MILVUS_HOST=apboa-milvus
MILVUS_PORT=19530
MILVUS_DATABASE=default

# Qdrant 配置（VECTOR_STORE_TYPE=qdrant 时生效）
QDRANT_HOST=apboa-qdrant
QDRANT_PORT=6334

# Elasticsearch 配置（VECTOR_STORE_TYPE=elasticsearch 时生效）
# Docker 内置 Elasticsearch 由 COMPOSE_PROFILES=elasticsearch 启动。
ELASTICSEARCH_IMAGE=docker.elastic.co/elasticsearch/elasticsearch:8.15.0
ELASTICSEARCH_URIS=http://apboa-elasticsearch:9200
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=
ELASTICSEARCH_API_KEY=
ELASTICSEARCH_INDEX_PREFIX=apboa_rag
ELASTICSEARCH_PORT=9200

# ==================== 镜像仓库配置 ====================
# Docker 镜像私有仓库前缀，留空则使用 Docker Hub
# 示例: DOCKER_REGISTRY=docker.your-company.com/
DOCKER_REGISTRY=

# ==================== 后端配置 ====================
BACKEND_PORT=3060
JWT_SECRET=ZJr8c2xF0y5b7yM+1H9v9cGZq6nZ5e0k5r3Cw7H8vJQ=

# 容器资源限制（防智能体耗尽宿主机）
BACKEND_MEM_LIMIT=8g
BACKEND_CPU_LIMIT=8
BACKEND_PIDS_LIMIT=1000
BACKEND_NPROC_LIMIT=1000
BACKEND_NOFILE_SOFT=32768
BACKEND_NOFILE_HARD=65536

# JVM 堆占容器内存上限的百分比，通过 -XX:MaxRAMPercentage 让 JVM 自动分配
# 容器内除 JVM 外还有 OS、Python、Node.js 等进程需要内存
# 示例：BACKEND_MEM_LIMIT=8g + 75% → JVM 堆约 6g
BACKEND_JAVA_HEAP_PERCENTAGE=75.0

# ==================== 前端配置 ====================
FRONTEND_PORT=80
VITE_APP_BASE_API=/web
VITE_APP_CONTEXT_PATH=/web

# 跨平台路径配置（在系统特定的 .env 中覆盖）
# DATA_PATH=./data
# LOG_PATH=./logs
