{
  "name": "ui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:doc": "vite --mode doc",
    "build": "run-p type-check \"build-only {@}\" --",
    "build:main": "run-p type-check \"build-only:main {@}\" --",
    "build:doc": "run-p type-check \"build-only:doc {@}\" --",
    "preview": "vite preview",
    "build-only": "vite build",
    "build-only:main": "vite build --mode main",
    "build-only:doc": "vite build --mode doc",
    "type-check": "vue-tsc --build",
    "lint": "run-s lint:*",
    "lint:oxlint": "oxlint . --fix",
    "lint:eslint": "eslint . --fix --cache",
    "format": "prettier --write --experimental-cli src/"
  },
